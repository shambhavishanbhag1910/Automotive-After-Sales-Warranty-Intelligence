# Default local mode uses SQLite and does not require any cloud account.
DATABASE_URL=sqlite:///./data/warranty_ai.db
SAMPLE_DATA_DIR=./data/sample
APP_ENV=local
LOG_LEVEL=INFO

# Optional LLM settings for future enhancement. The current demo runs without these.
LLM_PROVIDER=none
OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=

# API settings
API_HOST=0.0.0.0
API_PORT=8000
